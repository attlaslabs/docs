{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Attlas Documentation",
  "colors": {
    "primary": "#155dfc",
    "light": "#6492f6",
    "dark": "#155dfc"
  },
  "favicon": {
    "light": "/images/app-dark.png",
    "dark": "/images/app-dark.png"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://mintlify.com/docs",
          "icon": "book",
          "color": {
            "light": "#155dfc",
            "dark": "#155dfc"
          }
        },
        {
          "anchor": "Blog",
          "href": "https://attlas.so/blog",
          "icon": "newspaper",
          "color": {
            "light": "#155dfc",
            "dark": "#155dfc"
          }
        }
      ]
    },
    "groups": [
      {
        "group": "Get started",
        "expanded": true,
        "root": "start",
        "pages": [
          "start/add-source",
          "start/add-sources",
          "start/set-profile",
          "start/triggers",
          "start/customizations",
          "start/sharing-options",
          "start/invite-members"
        ]
      },
      {
        "group": "Basic features",
        "expanded": true,
        "root": "basic",
        "pages": [
          "basic/conversations",
          "basic/messages",
          "basic/analytics"
        ]
      },
      {
        "group": "Pro features",
        "expanded": true,
        "root": "features",
        "pages": [
          "pro/auto-sync",
          "pro/generate-questions",
          "pro/chats-restriction",
          "pro/invite-members"
        ]
      },
      {
        "group": "Good practices",
        "expanded": true,
        "root": "practices",
        "pages": [
          "practices/coverage-rate",
          "practices/corrections",
          "practices/knowledge-management"
        ]
      },
      {
        "group": "Playbooks",
        "expanded": true,
        "root": "playbooks",
        "pages": [
          "playbooks/companies",
          "playbooks/creators"
        ]
      },
      {
        "group": "Ressources",
        "expanded": true,
        "root": "ressources",
        "pages": [
          {
            "group": "Terms & Privacy",
            "expanded": true,
            "root": "legal",
            "pages": [
              "legal/privacy-cookies",
              "legal/terms-conditions",
              "legal/data-processing"
            ]
          },
          "faq",
          "media-kit"
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/app-dark.png",
    "dark": "/images/app-dark.png",
    "href": "https://attlas.so"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hello@attlas.so"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://attlas.so/dashboard"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/AttlasChat",
      "linkedin": "https://linkedin.com/company/attlas-so",
      "instagram": "https://www.instagram.com/attlas.so"
    }
  },
  "icons": {
    "library": "lucide"
  },
  "fonts": {
    "family": "Geist"
  },
  "interaction": {
    "drilldown": false
  },
  "errors": {
    "404": {
      "redirect": true
    }
  },
  "background": {
    "color": {
      "light": "#fafafa",
      "dark": "#141110"
    }
  }
}
