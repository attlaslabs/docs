{
  "theme": "almond",
  "name": "Attlas Documentation",
  "colors": {
    "primary": "#155dfc",
    "light": "#6492f6",
    "dark": "#155dfc"
  },
  "logo": {
    "light": "/images/logotype-light.png",
    "dark": "/images/logotype-dark.png"
  },
  "favicon": {
    "light": "/images/app-light.png",
    "dark": "/images/app-dark.png"
  },
  "background": {
    "color": {
      "light": "#ffffff",
      "dark": "#110e0e"
    }
  },
  "navbar": {
    "links": [
      {
        "href": "mailto:hello@attlas.so",
        "label": "Contact Us"
      },
      {
        "href": "https://attlas.so/login",
        "label": "Login"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://attlas.so/dashboard"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/AttlasChat",
      "linkedin": "https://linkedin.com/company/attlas-so",
      "instagram": "https://www.instagram.com/attlas.so"
    }
  },
  "fonts": {
    "family": "Geist"
  },
  "icons": {
    "library": "lucide"
  },
  "errors": {
    "404": {
      "redirect": true
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ],
    "display": "header"
  },
  "interaction": {
    "drilldown": false
  },
  "thumbnails": {
    "fonts": {
      "family": "Geist"
    },
    "background": "https://ofwppfqdauuyxblgkips.supabase.co/storage/v1/object/public/public-medias/documentation/thumbnails/default-thumb.png"
  },
  "seo": {
    "indexing": "navigable"
  },
  "metadata": {
    "timestamp": true
  },
  "search": {
    "prompt": "Search something..."
  },
  "$schema": "https://mintlify.com/docs.json",
  "redirects": [
    {
      "source": "/playbooks/link-in-bio",
      "destination": "/playbooks/creators/link-in-bio"
    },
    {
      "source": "/playbooks/creative-uses",
      "destination": "/playbooks/creators/creative-uses"
    },
    {
      "source": "/fr/docs",
      "destination": "/fr"
    },
    {
      "source": "/pt/docs",
      "destination": "/pt"
    }
  ],
