{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Attlas Documentation",
  "colors": {
    "primary": "#155dfc",
    "light": "#6492f6",
    "dark": "#155dfc"
  },
  "favicon": {
    "light": "/images/app-dark.png",
    "dark": "/images/app-dark.png"
  },
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "pages": [
          "index",
          "quickstart"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://mintlify.com/docs",
          "icon": "book",
          "color": {
            "light": "#155dfc",
            "dark": "#155dfc"
          }
        },
        {
          "anchor": "Blog",
          "href": "https://attlas.so/blog",
          "icon": "newspaper",
          "color": {
            "light": "#155dfc",
            "dark": "#155dfc"
          }
        }
      ]
    },
    "dropdowns": [
      {
        "dropdown": "Untitled Dropdown",
        "tabs": [
          {
            "tab": "Test"
          }
        ]
      },
      {
        "dropdown": "Getting started",
        "pages": [
          "sources",
          "profile",
          "triggers",
          "customization",
          "shares",
          "invites"
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/app-dark.png",
    "dark": "/images/app-dark.png",
    "href": "https://attlas.so"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hello@attlas.so"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.mintlify.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/AttlasChat",
      "linkedin": "https://linkedin.com/company/attlas-so",
      "instagram": "https://www.instagram.com/attlas.so"
    }
  },
  "icons": {
    "library": "lucide"
  },
  "fonts": {
    "family": "Geist"
  },
  "interaction": {
    "drilldown": false
  },
  "errors": {
    "404": {
      "redirect": true
    }
  },
  "background": {
    "color": {
      "light": "#fafafa",
      "dark": "#141110"
    }
  }
}
