{
  "theme": "almond",
  "name": "Attlas Documentation",
  "colors": {
    "primary": "#155dfc",
    "light": "#6492f6",
    "dark": "#155dfc"
  },
  "logo": {
    "light": "/images/logotype-light.png",
    "dark": "/images/logotype-dark.png",
    "href": "https://attlas.so/docs"
  },
  "favicon": {
    "light": "/images/app-light.png",
    "dark": "/images/app-dark.png"
  },
  "background": {
    "color": {
      "light": "#ffffff",
      "dark": "#110e0e"
    }
  },
  "navbar": {
    "links": [
      {
        "href": "mailto:hello@attlas.so",
        "label": "Contact Us"
      },
      {
        "href": "https://attlas.so/login",
        "label": "Login"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://attlas.so/dashboard"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/AttlasChat",
      "linkedin": "https://linkedin.com/company/attlas-so",
      "instagram": "https://www.instagram.com/attlas.so"
    }
  },
  "fonts": {
    "family": "Geist"
  },
  "icons": {
    "library": "lucide"
  },
  "errors": {
    "404": {
      "redirect": true
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ],
    "display": "header"
  },
  "interaction": {
    "drilldown": false
  },
  "thumbnails": {
    "fonts": {
      "family": "Geist"
    },
    "background": "https://ofwppfqdauuyxblgkips.supabase.co/storage/v1/object/public/public-medias/documentation/thumbnails/default-thumb.png"
  },
  "seo": {
    "indexing": "navigable"
  },
  "metadata": {
    "timestamp": true
  },
  "search": {
    "prompt": "Search something..."
  },
  "$schema": "https://mintlify.com/docs.json",
  "navigation": {
    "groups": [
      {
        "group": "Learn",
        "pages": [
          {
            "group": "Get started",
            "icon": "play",
            "root": "start",
            "pages": [
              "start/sources",
              "start/profile",
              "start/triggers",
              "start/themes",
              "start/sharing"
            ]
          },
          {
            "group": "Basic features",
            "icon": "box",
            "root": "basic",
            "pages": [
              "basic/link-aggregator",
              "basic/ai-chat",
              "basic/ai-settings",
              "basic/conversation-history",
              "basic/analytics"
            ]
          },
          {
            "group": "Pro features",
            "icon": "gift",
            "root": "pro",
            "pages": [
              "pro/workspaces",
              "pro/reviewing",
              "pro/autosync",
              "pro/opengraph",
              "pro/customization"
            ]
          },
          {
            "group": "Best practices",
            "icon": "trophy",
            "root": "practices",
            "pages": [
              "practices/best-practices-for-using-attlas",
              "practices/structuring-content",
              "practices/coverage-rate",
              "practices/corrections",
              "practices/archetypes"
            ]
          },
          {
            "group": "Integrations",
            "root": "integrations",
            "icon": "shapes",
            "pages": [
              "integrations/google-calendar",
              "integrations/sql-database",
              "integrations/tally",
              "integrations/notion"
            ]
          },
          {
            "group": "Playbooks",
            "icon": "folder-bookmark",
            "root": "playbooks",
            "pages": [
              "playbooks/companies",
              "playbooks/smarter-link-in-bio",
              "playbooks/attlas-performance",
              "playbooks/creative-uses",
              "playbooks/how-to-start"
            ]
          },
          {
            "group": "Ressources",
            "icon": "book-marked",
            "root": "ressources",
            "pages": [
              {
                "group": "Terms & Privacy",
                "expanded": true,
                "root": "legal",
                "pages": [
                  "legal/privacy",
                  "legal/terms",
                  "legal/data"
                ],
                "hidden": true
              },
              "faq",
              "mediakit"
            ],
            "hidden": true
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "color": {
            "light": "#155dfc",
            "dark": "#155dfc"
          },
          "href": "https://attlas.so"
        },
        {
          "anchor": "Blog",
          "icon": "newspaper",
          "color": {
            "light": "#155dfc",
            "dark": "#155dfc"
          },
          "href": "https://attlas.so/blog"
        }
      ]
    }
  }
}
